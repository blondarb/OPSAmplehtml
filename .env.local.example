# AWS Cognito Authentication
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=your_cognito_client_id_here
COGNITO_REGION=us-east-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id_here
NEXT_PUBLIC_COGNITO_REGION=us-east-2

# Database
DATABASE_URL=postgresql://user:password@host:5432/ops_amplehtml

# Secret keys - NEVER commit these
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# AWS Bedrock Configuration (used for all non-Realtime AI calls)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# OpenAI API Key (only needed for Realtime API features: voice historian, intake voice)
OPENAI_API_KEY=your_openai_api_key_here

# ─── AI Historian (Phase 1 of Realtime API upgrade) ─────────────────────────
# Override the model (default: gpt-realtime-2, the flagship GPT-5-class
# Realtime model). Set to 'gpt-realtime' to hot-revert to the standard GA model.
OPENAI_HISTORIAN_REALTIME_MODEL=gpt-realtime-2

# Override turn detection (default: semantic_vad). Set to 'server_vad' to
# restore the PR #105 tuning (threshold=0.65, silence_duration_ms=1200).
HISTORIAN_TURN_DETECTION_MODE=semantic_vad

# ── Speech-biomarker Praat sidecar (SDNE speech-trial bake-off) ──────────────
# src/lib/voice/engines.ts (parselmouthEngine) POSTs to ${VOICE_PRAAT_URL}/score.
# Leave unset to run the pure-TS engine only (the bake-off degrades gracefully).
# Deployed 2026-07-01: SDNE stack sdne-voice-praat (us-east-2), arm64 Lambda + Function URL.
# Set WITHOUT a trailing slash. For the voice-bench CLI, export it in the shell.
VOICE_PRAAT_URL=https://tqrxydtkl3s3wa22dzks4dy7ge0nruel.lambda-url.us-east-2.on.aws
