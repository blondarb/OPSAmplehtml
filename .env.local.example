# AWS Cognito Authentication
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=your_cognito_client_id_here
COGNITO_REGION=us-east-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id_here
NEXT_PUBLIC_COGNITO_REGION=us-east-2

# Database
DATABASE_URL=postgresql://user:password@host:5432/ops_amplehtml

# Secret keys - NEVER commit these
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# AWS Bedrock Configuration (used for all non-Realtime AI calls)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# OpenAI API Key (only needed for Realtime API features: voice historian, intake voice)
OPENAI_API_KEY=your_openai_api_key_here

# ─── AI Historian (Phase 1 of Realtime API upgrade) ─────────────────────────
# Override the model (default: gpt-realtime-2, the flagship GPT-5-class
# Realtime model). Set to 'gpt-realtime' to hot-revert to the standard GA model.
OPENAI_HISTORIAN_REALTIME_MODEL=gpt-realtime-2

# Override turn detection (default: semantic_vad). Set to 'server_vad' to
# restore the PR #105 tuning (threshold=0.65, silence_duration_ms=1200).
HISTORIAN_TURN_DETECTION_MODE=semantic_vad

# ─── Voice provider (Nova Sonic voice migration) ────────────────────────────
# Selects the transport the AI Historian + Follow-Up voice sessions use.
# 'openai' (default) = today's production path (WebRTC + Realtime API,
# unchanged). 'nova' = WebSocket relay -> Bedrock amazon.nova-2-sonic-v1:0.
# A client `provider` field (from the in-app voice-engine toggle) always wins
# over this env var; this only sets the server-side fallback when the client
# doesn't specify one. Leave unset/'openai' in every environment until Nova
# has been through live verification (see docs/plans/2026-06-05-nova-sonic-
# voice-migration.md) — flipping this to 'nova' engages Nova by default for
# every historian/follow-up session with no toggle interaction.
VOICE_PROVIDER=openai

# WebSocket URL of the deployed Nova Sonic relay (services/nova-sonic-relay).
# Required only when VOICE_PROVIDER=nova or a client selects Nova via the
# toggle — the 'openai' path never reads this. Leave unset in this repo until
# the relay is deployed (App Runner); the Nova path fails closed (relayUrl
# missing -> provider throws -> hook surfaces a startup error) rather than
# silently falling back to OpenAI.
NOVA_SONIC_RELAY_URL=

# Optional Nova Sonic voice ID override. Leave unset to use the relay's
# default voice.
NOVA_SONIC_VOICE_ID=

# Shared HMAC secret used to authenticate the Nova Sonic relay's WebSocket
# upgrade. This app mints a short-lived token (session route) that the
# browser sends as a WS subprotocol; the relay (services/nova-sonic-relay,
# same env var name) validates it. MUST be set to the SAME value on both
# sides. Leave unset here to match "Nova stays fully inert" — but note the
# relay is fail-closed: an unset secret on the RELAY side rejects every
# connection regardless of what this app sends, and an unset secret HERE
# means the app mints no token at all (the relay then rejects, which is the
# correct fail-closed outcome, not a bug). NEVER commit the real value —
# store it in AWS Secrets Manager / the Amplify + App Runner env var UI.
NOVA_RELAY_SHARED_SECRET=

# Comma-separated allowlist of exact Origin header values the relay accepts
# (e.g. https://app.neuroplans.app). Relay-side only — set on the App Runner
# service, not here. Leave unset there to skip the origin check (the token
# above is the sole gate). Documented here for completeness since it's part
# of the same auth story.
NOVA_RELAY_ALLOWED_ORIGINS=

# ── AI Historian durable transcript (Historian Validation Suite, Task 1) ────
# HMAC secret signing the transcript-flush bearer token (mint:
# src/lib/historian/flushToken.ts, mirrors mintNovaRelayToken above; verify:
# POST /api/ai/historian/transcript-flush). Falls back to
# NOVA_RELAY_SHARED_SECRET when unset, so most environments need no new
# secret. Only set this separately if you want the flush token signed with a
# different key than the Nova relay handshake token.
HISTORIAN_FLUSH_SECRET=

# ── Speech-biomarker Praat sidecar (SDNE speech-trial bake-off) ──────────────
# src/lib/voice/engines.ts (parselmouthEngine) POSTs to ${VOICE_PRAAT_URL}/score.
# Leave unset to run the pure-TS engine only (the bake-off degrades gracefully).
# Deployed 2026-07-01: SDNE stack sdne-voice-praat (us-east-2), arm64 Lambda + Function URL.
# Set WITHOUT a trailing slash. For the voice-bench CLI, export it in the shell.
VOICE_PRAAT_URL=https://tqrxydtkl3s3wa22dzks4dy7ge0nruel.lambda-url.us-east-2.on.aws
# Shared x-api-key required by the deployed sidecar /score for real-subject PHI
# trials (Secrets Manager: sevaro/voice-praat/api-key). Leave unset for the open
# local/synthetic path. engines.ts sends it when present.
VOICE_PRAAT_API_KEY=

# ── Clara voice test (/rnd/clara, R&D / internal only) ───────────────────────
# Shows the "R&D / Internal Testing" section (linking to /rnd/clara) at the
# bottom of the homepage. Default OFF — the homepage renders byte-identical
# to before this feature existed when unset/false. Client-side flag (inlined
# at build time), so it must be present at BUILD time to take effect.
NEXT_PUBLIC_RND_SECTION_ENABLED=false

# Password gate for /rnd/clara (src/lib/clara/testGate.ts). Server-side only
# — never prefix with NEXT_PUBLIC_. Leave unset to fail-closed (the page always
# shows "not configured", never accepts any password). Set a real value only
# in non-production env var stores (Amplify env vars UI), never committed here.
CLARA_TEST_PASSWORD=

# Optional override for Clara's per-turn classifier model (default: Haiku 4.5,
# same tier as the FAQ POC classifier). Sonnet 4.6 (BEDROCK_MODEL in
# src/lib/bedrock.ts) is used automatically for nothing here — this route only
# ever calls the classifier tier, matching sevaro-voice-agent's
# maxTokens:400/temperature:0.4 call shape.
BEDROCK_CLARA_CLASSIFIER_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Clara's browser voice test reuses the SAME Nova Sonic relay + shared secret
# as the AI Historian above (NOVA_SONIC_RELAY_URL / NOVA_SONIC_VOICE_ID /
# NOVA_RELAY_SHARED_SECRET) — no separate relay config needed.
